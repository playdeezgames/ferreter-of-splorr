@page "/"

<PageTitle>Ferreter of SPLORR!!</PageTitle>

<table>
	<tr>
		<td>
			@foreach (var line in context.GetLines())
			{
				@line

				<br />
			}
		</td>
	</tr>
	<tr>
		<td>
			<EditForm Model="@inputModel" OnValidSubmit="HandleSubmit">
				<InputText @bind-Value="@inputModel.Text"/>
				<button type="submit">GO!</button>
			</EditForm>
		</td>
	</tr>
</table>

@code{
	InputModel inputModel = new();
	IUIContext context = new UIContext();
	protected override async Task OnInitializedAsync()
	{
		await base.OnInitializedAsync();
		await context.InitializeAsync();
	}
	void HandleSubmit()
	{
		if(inputModel.Text != null)
		{
			context.HandleInput(inputModel.Text);
			inputModel.Text = null;
		}
	}

	class InputModel
	{
		public string? Text { get; set; }
	}
}